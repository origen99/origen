---
interface NavItem {
  id: string;
  label: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Navegacion de secciones de Home">
  <ul>
    {items.map((item: NavItem) => (
      <li><a href={`#${item.id}`}>{item.label}</a></li>
    ))}
  </ul>
</nav>
